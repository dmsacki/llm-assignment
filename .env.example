# Copy this file to ".env" and adjust values as needed.
# This is the ONLY file you should edit to configure the app.
# Do not commit the real ".env" file to version control.

# --- Ollama / LLM settings ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Request behaviour ---
REQUEST_TIMEOUT_SECONDS=30
MAX_QUESTION_LENGTH=500

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE_PATH=backend/logs/app.log
FEEDBACK_FILE_PATH=backend/logs/feedback.jsonl

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Scraper ---
SCRAPER_CACHE_PATH=backend/data/scraped_cache.json
SCRAPER_TIMEOUT_SECONDS=30
SCRAPE_ON_STARTUP=true
SCRAPER_DELAY_SECONDS=0.5
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_FACTOR=1.0
SCRAPER_CHECK_ROBOTS_TXT=true
SCRAPER_CHUNK_MIN_CHARS=100
SCRAPER_CHUNK_MAX_CHARS=2000

# --- Frontend ---
BACKEND_URL=http://localhost:8000

# --- Retrieval-augmented generation ---
FAQ_FILE_PATH=backend/data/university_faq.md
PDF_DIRECTORY=backend/data/pdfs
