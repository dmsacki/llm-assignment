# Copy this file to ".env" and adjust values as needed.
# This is the ONLY file you should edit to configure the app.
# Do not commit the real ".env" file to version control.

# --- Ollama / LLM settings ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Request behaviour ---
REQUEST_TIMEOUT_SECONDS=30
MAX_QUESTION_LENGTH=500

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE_PATH=backend/logs/app.log
FEEDBACK_FILE_PATH=backend/logs/feedback.jsonl

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ---
BACKEND_URL=http://localhost:8000
